{
  "name": "config-compartor",
  "version": "1.0.0",
  "description": "Kubernetes Config Comparator - Compare secrets and configmaps between clusters",
  "main": "dist/backend/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon --exec ts-node src/backend/index.ts",
    "dev:frontend": "cd frontend && npm start",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "cd frontend && npm run build",
    "start": "node dist/backend/index.js",
    "install:frontend": "cd frontend && npm install"
  },
  "dependencies": {
    "express": "^4.22.1",
    "cors": "^2.8.6",
    "multer": "2.0.2",
    "@kubernetes/client-node": "^0.20.0",
    "js-yaml": "^4.1.1",
    "diff": "^5.2.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^20.19.37",
    "@types/express": "^4.17.25",
    "@types/cors": "^2.8.19",
    "@types/multer": "^1.4.13",
    "@types/js-yaml": "^4.0.9",
    "@types/diff": "^5.2.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  },
  "private": true
}
